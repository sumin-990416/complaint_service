# Copy this file to .env and fill in the values

# 공공데이터포털 인증키 (Decoding)
service_Key=YOUR_SERVICE_KEY

# PostgreSQL 연결 URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/complaint_service

# 공공 API 기본 URL
PUBLIC_API_BASE=https://apis.data.go.kr/B551982/cso_v2

# 카카오 지도 JavaScript API 키 (https://developers.kakao.com)
VITE_KAKAO_MAPS_KEY=YOUR_KAKAO_JAVASCRIPT_KEY
